---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import SocialButtons from '../components/SocialButtons.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../config';
---

<!DOCTYPE html>
<html lang="en">
    <head>
        <BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
    </head>
    <body>
        <Header headerTitle={SITE_TITLE} />
        <main class="pb-2">
            <div class="hero min-h-[78vh] bg-base-200">
                <div class="hero-content flex-col md:flex-row">
                    <div class="mr-8">
                        <img
                            src="/me-cropped.jpg"
                            alt="Picture of Jethro amongst yellow plants"
                            width="auto"
                            class="w-40 md:w-80 rounded-full shadow-2xl p-1 bg-clip-padding bg-gradient-to-r from-[#D60270] via-[#9B4F96] to-[#0038A8]"
                        />
                    </div>

                    <div class="prose">
                        <h1 class="text-center md:text-left">Hello, I'm Jethro 👋</h1>
                        <p class="text-center md:text-left">
                            Welcome to my website! I'm a fullstack developer but my passions lie in
                            backend development, optimisation, and building developer tooling.
                        </p>

                        <p>
                            I also enjoy writing and have written several articles that you can find
                            on the <a class="link" href="/blog">Blog</a> page.
                        </p>

                        <p>To see my projects and work check out my Github and LinkedIn profiles</p>
                        <div class="flex justify-center md:justify-start">
                            <div>
                                <SocialButtons />
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </main>
        <Footer />
    </body>
</html>
