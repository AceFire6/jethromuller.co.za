---
import { Icon } from 'astro-icon';

interface Props {
    linkClass?: string;
    iconClass?: string;
}

const { linkClass, iconClass } = Astro.props;
const extraLinkClasses: string = linkClass ?? '';
const linkClasses = ['no-underline', extraLinkClasses].join(' ');

const extraIconClasses: string = iconClass ?? '';
const iconClasses = ['inline-flex', 'h-10', extraIconClasses].join(' ');
---

<a href="mailto:admin@jethromuller.co.za" target="_blank" title="Email Address" class={linkClasses}>
    <Icon name="fa-regular:envelope" class={iconClasses} />
</a>
